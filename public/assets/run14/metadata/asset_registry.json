  "story_segments": [
    {
      "id": "seg_001",
      "order": 1,
      "summary": "年轻天才少女身处危险的挑战现场，内心充满恐惧但又坚定面对。",
      "text": "昏暗的挑战现场，弥漫着紧张的氛围，四周是危险的气息。一位年轻的天才少女身处其中，她眼神聪慧，眉头紧锁，脸上满是紧张。周围的环境仿佛暗藏着无数危机，随时可能向她袭来。少女的身体微微颤抖，她从未经历过如此危险的场景，心中充满了恐惧。但她那聪慧的眼神中，又透露出一丝坚定，她知道自己必须面对这一切。",
      "scene_ids": [
        "scene_001"
      ],
      "character_ids": [
        "char_001"
      ],
      "prop_ids": []
    },
    {
      "id": "seg_002",
      "order": 2,
      "summary": "少女在挑战中觉醒能力，光芒驱散危险，她惊喜地准备迎接新冒险。",
      "text": "突然，一股强大的压力向少女涌来，她感觉自己的呼吸都变得困难起来。在这生死攸关的时刻，少女的身体开始发生变化。光芒从她的体内闪耀而出，力量在她的身体里涌动。她的眼神变得更加明亮，脸上的恐惧也被兴奋所取代。少女觉醒了自己的能力，光芒照亮了整个挑战现场，危险的气息也随之消散。少女看着自己手中散发着光芒的力量，心中充满了惊喜。觉醒能力后的她，知道新的冒险即将展开，前方还有更多未知等待着她。",
      "scene_ids": [
        "scene_001"
      ],
